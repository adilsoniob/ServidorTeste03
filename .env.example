# Porta do servidor
PORT=4320

# Chave de API para autenticação (deve ser igual à configurada no admin do Vale Saúde)
WHATSAPP_API_KEY=VALE_SAUDE_2026

# URL base do sistema Vale Saúde Edge (para webhooks, se necessário)
VALE_SAUDE_API_URL=https://valesaude.onrender.com

# Pasta da sessão WhatsApp (produção: /data/session para persistência via volume)
SESSION_FOLDER=/data/session

# Pasta de autenticação do whatsapp-web.js (produção: /data/.wwebjs_auth)
AUTH_FOLDER=/data/.wwebjs_auth

# Configurações de produção
NODE_ENV=production
MAX_ACCOUNTS=1
STEALTH_ENABLED=false

# Rate limiting (mensagens por minuto por conta)
RATE_LIMIT_MAX_PER_MINUTE=20
